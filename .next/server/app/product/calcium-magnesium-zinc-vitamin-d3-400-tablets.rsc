1a:["$","section",null,{"className":"section","style":{"paddingTop":36},"children":["$","div",null,{"className":"container productDetailsShell","children":[["$","div",null,{"className":"productIntro","children":[["$","div",null,{"className":"productSpecCard","children":[["$","span",null,{"className":"eyebrow","children":"Quick specs"}],["$","dl",null,{"children":[["$","div",null,{"children":[["$","dt",null,{"children":"Format"}],["$","dd",null,{"children":"Tablets"}]]}],["$","div",null,{"children":[["$","dt",null,{"children":"Price"}],["$","dd",null,{"children":"TBA"}]]}],["$","div",null,{"children":[["$","dt",null,{"children":"Stock"}],["$","dd",null,{"children":[48," units"]}]]}],["$","div",null,{"children":[["$","dt",null,{"children":"Rating"}],["$","dd",null,{"children":[4.5," / 5"]}]]}],["$","div",null,{"children":[["$","dt",null,{"children":"Routine fit"}],["$","dd",null,{"children":"Joints"}]]}]]}]]}],["$","div",null,{"className":"routineFitCard","children":[["$","span",null,{"className":"eyebrow","children":"Fits these routines"}],[["$","div","bones-joints",{"children":[["$","strong",null,{"children":"Bones, joints and active living"}],["$","p",null,{"children":"Minerals, vitamin D/K, omega-3, and joint-focused formulas for movement routines."}]]}]]]}],[["$","span",null,{"className":"eyebrow","children":"Product overview"}],["$","h2",null,{"children":"Product overview"}],[["$","p","Modern life and busy schedules can make it difficult to get all of the vital nutrients, vitamins and minerals we need to be at our best, no matter how much effort we put into balancing our diet. Give yourself a boost with Calcium, Magnesium and Zinc with Vitamin D3 from Weightworld. Featuring a whole range of incredible vitamins and minerals that support the bones, muscles and natural defences , it’s a fantastic way to supplement a modern diet and feel at your best.",{"children":"Modern life and busy schedules can make it difficult to get all of the vital nutrients, vitamins and minerals we need to be at our best, no matter how much effort we put into balancing our diet. Give yourself a boost with Calcium, Magnesium and Zinc with Vitamin D3 from Weightworld. Featuring a whole range of incredible vitamins and minerals that support the bones, muscles and natural defences , it’s a fantastic way to supplement a modern diet and feel at your best."}]]]]}],["$","div",null,{"className":"productAccordions","children":[[["$","details","What Is Calcium, Magnesium, and Zinc with Vitamin D3?",{"className":"productAccordion","open":true,"children":[["$","summary",null,{"children":"What Is Calcium, Magnesium, and Zinc with Vitamin D3?"}],["$","div",null,{"className":"accordionBody","children":[[["$","p","Our Calcium Magnesium Zinc and Vitamin D3 tablets contain three of your body’s most important minerals. Though all of them can be found in a variety of food sources, it can be difficult to ensure you're getting the right amount while juggling a busy work schedule or taking care of the kids. These easy-to-take supplements ensure that your body is never lacking, so you can get on with your day whilst feeling your best.",{"children":"Our Calcium Magnesium Zinc and Vitamin D3 tablets contain three of your body’s most important minerals. Though all of them can be found in a variety of food sources, it can be difficult to ensure you're getting the right amount while juggling a busy work schedule or taking care of the kids. These easy-to-take supplements ensure that your body is never lacking, so you can get on with your day whilst feeling your best."}]],false]}]]}],["$","details","Key Ingredients & Benefits",{"className":"productAccordion","open":false,"children":[["$","summary",null,{"children":"Key Ingredients & Benefits"}],["$","div",null,{"className":"accordionBody","children":[[["$","p","Calcium is renowned for its vital role in the maintenance of our bones, but did you know that it helps ensure proper nerve function and targets the heart too? As calcium is most frequently found in dairy products, supplementation is a good way to ensure you get all the calcium your body needs, no matter your diet or lifestyle.",{"children":"Calcium is renowned for its vital role in the maintenance of our bones, but did you know that it helps ensure proper nerve function and targets the heart too? As calcium is most frequently found in dairy products, supplementation is a good way to ensure you get all the calcium your body needs, no matter your diet or lifestyle."}],"$L1c","$L1d"],"$L1e"]}]]}],"$L1f"],"$L20","$L21","$L22","$L23"]}]]}]}]
